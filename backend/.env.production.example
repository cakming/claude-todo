# ------------------------------------------------------------------------------
# Production backend environment for https://todo.dvlpr.sh
#
# Copy this to `backend/.env` ON THE VM and fill in the real secret values.
# This file (the .example) is safe to commit; the real backend/.env is NOT
# (it is gitignored) and must never be committed.
# ------------------------------------------------------------------------------

# --- MongoDB (already running on the VM) ---
# If Mongo runs locally on the VM without auth:
MONGODB_URI=mongodb://127.0.0.1:27017
# If it requires credentials/TLS, use the full form, e.g.:
# MONGODB_URI=mongodb://user:pass@127.0.0.1:27017/?authSource=admin
DB_NAME=vibe_todo_manager

# --- Server ---
PORT=3001
NODE_ENV=production

# --- CORS ---
# API and frontend share the origin (nginx same-origin proxy), so browser
# requests are same-origin. Set this to the site anyway for safety / non-browser clients.
CORS_ORIGIN=https://todo.dvlpr.sh

# --- Authentication (enabled in production) ---
AUTH_ENABLED=true
# Generate ON THE VM with:  openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRES_IN=7d
