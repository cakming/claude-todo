# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
DB_NAME=vibe_todo_manager

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Authentication Configuration
# Set to 'true' to enable authentication, 'false' or omit to disable
AUTH_ENABLED=false

# JWT Configuration (required if AUTH_ENABLED=true)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Logging: pino level (fatal|error|warn|info|debug|trace|silent).
# Defaults to 'info' (or 'silent' under NODE_ENV=test).
LOG_LEVEL=info

# Trash retention in days: trashed items older than this are auto-purged when
# the trash is viewed. 0 disables auto-purge. Defaults to 30.
TRASH_RETENTION_DAYS=30
