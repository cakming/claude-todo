# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
DB_NAME=vibe_todo_manager

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Image storage: set GCS_BUCKET to store uploads in a Google Cloud Storage
# bucket (recommended in production — keeps MongoDB lean). Leave blank to store
# images in MongoDB via GridFS. Auth uses Application Default Credentials
# (GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json, or the GCE metadata server
# when running on a Google VM).
GCS_BUCKET=
# GOOGLE_APPLICATION_CREDENTIALS=/etc/vibe-todo/gcs-key.json

# Authentication Configuration
# Set to 'true' to enable authentication, 'false' or omit to disable
AUTH_ENABLED=false

# JWT Configuration (required if AUTH_ENABLED=true)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Logging: pino level (fatal|error|warn|info|debug|trace|silent).
# Defaults to 'info' (or 'silent' under NODE_ENV=test).
LOG_LEVEL=info

# Trash retention in days: trashed items older than this are auto-purged when
# the trash is viewed. 0 disables auto-purge. Defaults to 30.
TRASH_RETENTION_DAYS=30

# Notifications (optional) --------------------------------------------------
# Email: SMTP for password reset and @mention notifications. Without SMTP_HOST
# the app logs emails to the console instead (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@vibe-todo.local

# Telegram: set a bot token to enable Telegram @mention notifications. Users
# link their chat id via POST /api/auth/telegram-link. Leave blank to disable.
TELEGRAM_BOT_TOKEN=
