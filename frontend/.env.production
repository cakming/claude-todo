# Production frontend config for https://todo.dvlpr.sh
#
# The API is served on the SAME origin via nginx (which proxies /api -> backend),
# so a relative base URL is used. This avoids CORS entirely in the browser.
# The health check calls `${VITE_API_URL}`.replace('/api','') + '/health' => '/health'.
VITE_API_URL=/api
